# 顺丰全自动方案 - 环境变量配置模板
# 复制为 .env 并修改: cp .env.example .env

# 中继服务器 API 鉴权 Token（必须设置）
SF_RELAY_TOKEN=请替换为随机字符串

# Cookie 提取间隔（秒），默认 3600 = 1小时
# 建议不低于 1800（30分钟）
EXTRACT_INTERVAL=3600

# Bark 推送 Key（iOS 推荐）
# 获取方式: App Store 搜索 Bark 安装后自动生成
SF_BARK_KEY=

# PushPlus Token（通用推送）
# 获取方式: https://www.pushplus.plus/ 微信扫码登录
SF_PUSHPLUS_TOKEN=
