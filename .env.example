# ============================================
# 顺丰速运自动化 - 环境变量配置
# 复制此文件为 .env 并修改: cp .env.example .env
# 或通过 QQ 发送 顺丰登录 自动配置
# ============================================

# ---------- 顺丰账号 ----------
# sfsyUrl 获取方式:
#   ① 顺丰APP绑定微信后，前往 sm.linzixuan.work 扫码复制
#   ② 打开小程序或APP-我的-积分，手动抓包 URL
#   ③ 或直接粘贴 Cookie 字符串
# 多账号用换行分隔
sfsyUrl=

# ---------- 青龙面板 ----------
# 配置后 顺丰登录/更新 会自动提交环境变量到青龙
QL_URL=http://127.0.0.1:5700
QL_CLIENT_ID=
QL_CLIENT_SECRET=

# ---------- 可选：Docker 中继方案 ----------
# 如需全自动 Cookie 刷新，部署 Docker 后填写
SF_RELAY_URL=
SF_RELAY_TOKEN=

# ---------- 可选：代理配置 ----------
SF_PROXY_API_URL=
