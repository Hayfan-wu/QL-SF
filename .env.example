# ============================================
#  QL-SF 顺丰速运自动化 - 环境变量配置
# ============================================
#
#  简单模式: 复制为 .env，填写 sfsyUrl 和青龙配置
#  Docker 模式: 在 Portainer Stack 的 Env vars 中填写
#
# ============================================

# ---------- 顺丰账号 ----------
# sfsyUrl 获取方式:
#   ① 顺丰APP绑定微信后，前往 sm.linzixuan.work 扫码复制
#   ② 打开小程序或APP-我的-积分，手动抓包 URL
#   ③ 或直接粘贴 Cookie 字符串
# 多账号用换行分隔
sfsyUrl=

# ---------- 青龙面板 ----------
# 配置后 QQ 发 顺丰登录 会自动提交环境变量到青龙
QL_URL=http://127.0.0.1:5700
QL_CLIENT_ID=
QL_CLIENT_SECRET=

# ---------- Docker 中继方案（Docker 模式必填） ----------
# 在 Portainer Stack 的 Env vars 中设置
SF_RELAY_TOKEN=sf123456token
SF_BARK_KEY=
SF_PUSHPLUS_TOKEN=
EXTRACT_INTERVAL=3600

# ---------- 可选：代理配置 ----------
SF_PROXY_API_URL=
